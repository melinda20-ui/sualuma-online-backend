+
+    const answer = pickAnswer(data);
+
+    return {
+      ok: response.ok && !!answer,
+      status: response.status,
+      answer,
+      raw: data,
+    };
+  } catch (error: any) {
+    return {
+      ok: false,
+      status: 0,
